APP_NAME="BSA API"
APP_ENV=production
APP_KEY=                          # ★ Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.bsa.example.com
ASSET_URL=https://api.bsa.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────
# On cPanel, the DB name and user will be prefixed: rishipa2_<name>
# DB was created via cPanel → MySQL Databases
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rishipa2_bsa          # ✅ already created
DB_USERNAME=rishipa2_bsa_user     # ★ create this user in cPanel → MySQL Databases → MySQL Users
DB_PASSWORD=                         # ★ password you set for that user

# ─── Session & Cache ───────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# ─── Mail ──────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.bsa.example.com
MAIL_PORT=587
MAIL_USERNAME=hello@bsa.example.com
MAIL_PASSWORD=                      # ★ cPanel email password
MAIL_FROM_ADDRESS="hello@bsa.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Frontend origin (CORS & redirects) ────────────────────
FRONTEND_URL=https://bsa.example.com

# ─── Sanctum ───────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=bsa.example.com

# ─── BSA custom ─────────────────────────────────────────
# ★ Generate: openssl rand -hex 32
OTP_SECRET=

# ─── Payment gateways ─────────────────────────────────────
KHALTI_SECRET=
KHALTI_PUBLIC_KEY=
ESEWA_MERCHANT_CODE=

# ─── SMS ───────────────────────────────────────────────────
SPARROW_TOKEN=
SPARROW_FROM=BSA

# ─── Cloudinary ────────────────────────────────────────────
CLOUDINARY_URL=                     # cloudinary://API_KEY:API_SECRET@dhknx0eac
CLOUDINARY_CLOUD_NAME=dhknx0eac
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Google Maps (server-side geocoding) ───────────────────
GOOGLE_MAPS_SERVER_KEY=

# ─── Analytics (Umami) ────────────────────────────────────
# Get the share URL from Umami Cloud → Website Settings → Share
UMAMI_SHARE_URL=

VITE_APP_NAME="${APP_NAME}"
