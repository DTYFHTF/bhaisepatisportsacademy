APP_NAME="Bhaisepati Sports Academy API"
APP_ENV=production
APP_KEY=                          # ★ Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.bsa.example.com
# ★ PRODUCTION ONLY: ensures Filament/Livewire JS/CSS load from right domain
ASSET_URL=https://api.bsa.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────
# ★ PRODUCTION: babal.host cPanel > MySQL Databases
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                      # ★ from cPanel
DB_USERNAME=                      # ★ from cPanel
DB_PASSWORD=                      # ★ from cPanel

# ─── Session & Cache ───────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# ─── Mail ──────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.bsa.example.com  # ★ cPanel email
MAIL_PORT=587
MAIL_USERNAME=info@bhaisepatisportsacademy.com.np
MAIL_PASSWORD=                    # ★ email password
MAIL_FROM_ADDRESS="info@bhaisepatisportsacademy.com.np"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Frontend origin (CORS & redirects) ────────────────────
FRONTEND_URL=https://bsa.example.com

# ─── Sanctum ───────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=bsa.example.com

# ─── BSA custom ─────────────────────────────────────────
# ★ Generate: openssl rand -hex 32
OTP_SECRET=

# ─── Payment gateways ─────────────────────────────────────
KHALTI_SECRET=
KHALTI_PUBLIC_KEY=
ESEWA_MERCHANT_CODE=

# ─── SMS ───────────────────────────────────────────────────
# SparrowSMS token can be reused across projects — it's per-account,
# not per-app. Change SPARROW_FROM to match this project's sender name.
SPARROW_TOKEN=                    # ★ from api.sparrowsms.com dashboard
SPARROW_FROM=BSA

# ─── Cloudinary ────────────────────────────────────────────
# Only CLOUDINARY_CLOUD_NAME is required — images are referenced by
# Public ID only (no server-side upload). API key/secret not needed
# unless you add SDK-based uploads in future.
CLOUDINARY_CLOUD_NAME=dhknx0eac
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME  # optional
# CLOUDINARY_API_KEY=                                         # optional
# CLOUDINARY_API_SECRET=                                      # optional

# ─── Google Maps (server-side geocoding, future use) ───────
GOOGLE_MAPS_SERVER_KEY=                   # ★ from Google Cloud Console → APIs & Services → Credentials

# ─── Analytics (Umami) ────────────────────────────────────
# UMAMI_SHARE_URL  → embeds the public analytics iframe in the admin panel
# Get it: Umami dashboard → Website → Settings → Share → enable → copy URL
UMAMI_SHARE_URL=
UMAMI_SHARE_URL=

VITE_APP_NAME="${APP_NAME}"
