# ─── API ─────────────────────────────────────────────────────────
# Server-only (used by Nuxt proxy/SSR) — NEVER exposed to browser
# Local Herd backend domain for development
NUXT_API_BASE=http://bsa-backend.test/api

# Public API base (client-side calls)
# ★ LOCAL HERD: http://bsa-backend.test/api
# ★ PRODUCTION: https://api.bhaisepatisportsacademy.com.np/api
NUXT_PUBLIC_API_BASE=http://bsa-backend.test/api

# ─── Site ─────────────────────────────────────────────────────────
# ★ PRODUCTION: https://bsa.example.com
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Google Maps ─────────────────────────────────────────────────
# ★ Browser-restricted API key (Maps JS, Places, Geocoding)
# Restrict to https://bsa.example.com/* in Google Cloud Console
# Value is injected via GitHub Actions secret: NUXT_PUBLIC_GOOGLE_MAPS_KEY
NUXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Analytics (Umami) ──────────────────────────────────────
# Tracking script injected in browser (umami.client.ts plugin)
# Host: your Umami instance (cloud.umami.is or self-hosted)
# Website ID: Umami dashboard → Website → Settings → Website ID (UUID)
NUXT_PUBLIC_UMAMI_HOST=https://cloud.umami.is
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
